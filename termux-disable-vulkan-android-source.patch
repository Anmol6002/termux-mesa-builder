+if(NOT CMAKE_CXX_FLAGS MATCHES "VK_USE_PLATFORM_ANDROID_KHR")
+	list(REMOVE_ITEM BASE_SRC "${CMAKE_CURRENT_SOURCE_DIR}/VulkanAndroid.cpp")
+endif()
